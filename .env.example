# Application
APP_NAME="SpendGraph AI API"
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'

# Local authentication (development/test only)
DEV_AUTH_ENABLED=true
DEV_USER_ID=00000000-0000-4000-8000-000000000001
# Set false for an empty development ledger after migrations.
DEMO_SEED_ENABLED=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=spendgraph
POSTGRES_PASSWORD=spendgraph
POSTGRES_DB=spendgraph
POSTGRES_PORT=5432
# Optional full SQLAlchemy URL override. PostgreSQL parts above are used when omitted.
# DATABASE_URL=postgresql+psycopg://spendgraph:spendgraph@localhost:5432/spendgraph

# Web
WEB_HOST=127.0.0.1
WEB_PORT=5173
VITE_GRAPHQL_URL=/graphql

# Compose publishes development ports on loopback by default.
BIND_HOST=127.0.0.1
